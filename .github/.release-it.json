{
  "git": {
    "push": false,
    "commit": false,
    "tag": false,
    "commitsPath": ".",
    "requireUpstream": false,
    "getLatestTagFromAllRefs": true
  },
  "github": {
    "release": false
  },
  "npm": {
    "publish": false
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": "conventionalcommits",
      "infile": "CHANGELOG.md",
      "gitRawCommitsOpts": {
        "path": "."
      },
      "commitsOpts": {
        "path": "."
      }
    },
    "@release-it/bumper": {
      "out": ".claude-plugin/plugin.json"
    }
  }
}
